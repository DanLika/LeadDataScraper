# Direct (top-level) Python dependencies. The lockfile `requirements.txt`
# is regenerated from this file via:
#
#     pip-compile --generate-hashes --strip-extras requirements.in
#
# `--generate-hashes` adds sha256 of every wheel/sdist on PyPI to the
# lockfile, so a future PyPI compromise that publishes a malicious
# package with the same VERSION (rare but happens) fails the
# `pip install --require-hashes` step in CI + Dockerfile.
#
# Pin patches conservatively (==) on security-critical libs to avoid
# implicit minor-version upgrades; use ~= on app-level deps where minor
# bumps are usually safe. Dependabot bumps both via the `pip` ecosystem
# in .github/dependabot.yml.
#
# Operator one-time setup:
#   pip install pip-tools
#   make lock-python   # regenerates requirements.txt with hashes

pandas==2.3.3
numpy==2.2.3
requests==2.33.0
beautifulsoup4==4.13.3
lxml==6.1.1
google-genai==1.12.1
urllib3==2.7.0
fastapi==0.121.0
uvicorn==0.34.0
python-multipart==0.0.29
supabase==2.29.0
python-dotenv==1.2.2
aiohttp==3.13.5
# Transitive of aiohttp on Python 3.10 (Dockerfile base image
# `mcr.microsoft.com/playwright/python:v1.40.0-jammy` is py3.10).
# On Python 3.11+ aiohttp uses stdlib `asyncio.timeout`, so a
# pip-compile run under 3.11 won't lock this implicitly — declared
# explicitly so the lockfile satisfies --require-hashes in the Docker
# build regardless of the host Python that ran `make lock-python`.
async-timeout==5.0.1
# Same root cause as async-timeout: py3.11+ has these in stdlib, so a
# pip-compile run on the host py3.11 won't lock them, but the py3.10
# Docker base needs them at install time.
#   exceptiongroup — transitive of anyio (stdlib ExceptionGroup on 3.11+)
#   tomli          — transitive of various build/test tools (stdlib tomllib on 3.11+)
exceptiongroup==1.3.1
tomli==2.4.1
playwright==1.50.0
aiofiles==23.2.1
slowapi==0.1.9
# Error tracking + APM. Free tier = 5k events/month, plenty for single-
# operator. `[fastapi]` extra pulls the StarletteIntegration + Pydantic
# context capture; backend init in backend/main.py. Range pin (not ==)
# because the current major-2 line is rapidly iterating; `make
# lock-python` pins the exact resolved version + sha256 hashes into
# requirements.txt — the lockfile is the actual byte-level guarantee.
sentry-sdk[fastapi]>=2.20,<3

# ---------------------------------------------------------------------------
# Dev-time deps (test runners) — pinned in requirements.in so `make
# lock-python` keeps them hash-locked alongside runtime deps. They DO ship
# in the Docker image (~50 KB total), which is acceptable until a separate
# `requirements-dev.in` is introduced; the alternative (untracked + ad-hoc
# `pip install` in operator venv) drops the suite when the venv is
# rebuilt and was the root cause of pytest-asyncio missing in the
# 2026-05-24 smoke run.
# ---------------------------------------------------------------------------
pytest-asyncio>=0.23,<1.0

# pytest-asyncio brings transitives that pip-compile under py3.11+ drops
# because their version specifiers are conditional (pytest<9,>=8.2;
# iniconfig>=1; pluggy>=1.5,<2). The py3.10 Docker base needs each
# pinned for --require-hashes to succeed.
pytest==8.4.2
iniconfig==2.0.0
pluggy==1.6.0
