# Environments
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Backups created when editing .env in place — never commit, may carry rotated secrets
.env.bak
.env*.bak

# Python
__pycache__/
*.py[cod]
*$py.class
.venv
venv/
ENV/
env/
build/
dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Node
node_modules/
.next/
out/
node-compile-cache/

# Database
*.sqlite
*.db
# Gemini-budget runtime SQLite (created lazily by src/utils/gemini_budget.py;
# default path data/gemini_budget.db).  Caught by *.db above but listed
# explicitly so operators see it in the runtime-artifact inventory.
data/gemini_budget.db
data/gemini_budget.db-journal
data/gemini_budget.db-wal
data/gemini_budget.db-shm

# OS
.DS_Store
Thumbs.db

# Project specific
tmp_*
leadscraper_*.csv
data/raw/*
!data/raw/.gitkeep
exports/*
!exports/.gitkeep
frontend/exports/
logs/

# Supabase CLI scratch state (project ref, org id, transient files)
supabase/.temp/
supabase/.branches/

# Images
*.jpg
*.jpeg
*.png
# Allowed PNG exceptions: committed visual baselines + integration-report screenshots
!frontend/e2e/visual.spec.ts-snapshots/*.png
!tests/integration/screenshots-*/*.png

# IDE / Tools
.claude/
.cursor/
.continue/
.jules/
.kiro/
.trae/
.playwright-mcp/
.agents/
.mcp.json
.coverage
skills-lock.json
.pytest_cache/
pytest-of-*/

# Performance traces (large JSON, regenerated per session)
tests/perf/*.json

# Per-run transcript dumps from tests/test_refusal_boundaries.py.
# CLAUDE.md "Live tier" notes: "Full transcript JSON dumped to a
# tempfile; path printed each run." Pattern is
# `refusal-boundaries-<timestamp>-<short-id>.json` and the files
# land at repo root via `tempfile.NamedTemporaryFile(...)`. They're
# debugging artifacts — keep on disk for forensics, ignore for
# tracking.
refusal-boundaries-*.json

# context-mode tool configs (local-only)
frontend/.cx_*.config.mjs

# Mutation testing (mutmut)
.mutmut-cache
html/

