# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Crawlbase API Tokens
CRAWLBASE_NORMAL_TOKEN=your_crawlbase_normal_token_here
CRAWLBASE_JS_TOKEN=your_crawlbase_js_token_here

# App Configuration
PORT=8000
DEBUG=False
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# API Authentication — set this to a strong random string for production
API_SECRET_KEY=your_api_secret_key_here

# Optional: signed-as name appended to outreach drafts (e.g. "Jane Smith")
OPERATOR_NAME=

# ─────────────────────────────────────────────────────────────────────
# Single-tenancy + admin gate
# ─────────────────────────────────────────────────────────────────────
# Required when OPERATOR_EMAIL is set in prod — backend lifespan asserts
# exactly this email is the only auth.users row. See ADR-001.
OPERATOR_EMAIL=operator@example.com

# Second factor on destructive endpoints (/leads/clear, /leads/demo,
# /operator/account, /admin/gemini-budget). MUST be set in prod or
# state-change endpoints 403. 32+ byte hex recommended.
ADMIN_TOKEN=<paste-32-byte-hex-here>

# ─────────────────────────────────────────────────────────────────────
# Instantly outbound (Phase 14/15 dispatcher)
# ─────────────────────────────────────────────────────────────────────
INSTANTLY_API_KEY=<paste-instantly-key-here>
INSTANTLY_DEFAULT_CAMPAIGN_ID=<paste-campaign-uuid-here>
# HMAC secret on inbound webhook events. Same value pasted into the
# Instantly dashboard webhook config. 32+ byte hex.
INSTANTLY_WEBHOOK_SIGNING_SECRET=<paste-32-byte-hex-here>

# ─────────────────────────────────────────────────────────────────────
# Public-facing URL bases (HTTPS in prod; trailing slash trimmed)
# ─────────────────────────────────────────────────────────────────────
# Frontend root (for absolute links in outbound mail, redirects).
PUBLIC_APP_BASE_URL=https://your-frontend.example.com
# Unsubscribe link base — may equal PUBLIC_APP_BASE_URL or a dedicated
# /unsubscribe-host depending on deliverability isolation.
UNSUBSCRIBE_BASE_URL=https://your-frontend.example.com
# HMAC secret for the RFC 8058 List-Unsubscribe token. 32+ byte hex.
UNSUBSCRIBE_TOKEN_SECRET=<paste-32-byte-hex-here>

# ─────────────────────────────────────────────────────────────────────
# Ops automation (Render Management API access)
# ─────────────────────────────────────────────────────────────────────
# Personal Access Token from https://dashboard.render.com/u/settings#api-keys.
# Scoped to single workspace. Used by ops scripts + local diagnostics.
# Treat as Render-account-equivalent.
RENDER_API_KEY=<paste-render-pat-here>
